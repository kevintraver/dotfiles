#!/bin/zsh
# Focus or open a URL in Zen Browser

if [[ -z "$1" ]]; then
  echo "Usage: zen-focus-tab <url>" >&2
  exit 1
fi

url="$1"
BT="/Users/kevin/.local/bin/bt"

open_url() {
  [[ ! "$url" =~ ^https?:// ]] && url="https://$url"
  open -a "Zen Browser" "$url"
}

# Convert to Chrome match pattern
[[ "$url" =~ ^https?:// ]] && base="${url%/}" || base="*://${url%/}"

# Try wildcard first, then exact for URLs with paths
# (bare *://host hangs, but *://host/path is safe)
# Sort by lastAccessed (4th col) descending to get most recent tab
tab_line=$($BT query -url "$base/*" --last-accessed 2>/dev/null | sort -t$'\t' -k4 -nr | head -1)
if [[ -z "$tab_line" && "${base#*://}" == */* ]]; then
  tab_line=$($BT query -url "$base" --last-accessed 2>/dev/null | sort -t$'\t' -k4 -nr | head -1)
fi

if [[ -n "$tab_line" ]]; then
  IFS=$'\t' read -r tab_id _ <<< "$tab_line"
  if $BT activate --focused "$tab_id" 2>/dev/null; then
    open -a "Zen Browser" 2>/dev/null
  else
    open_url
  fi
else
  open_url
fi
